variable = "Z_hat",
bins = c(15, 30, 40, 80, 120,
160, 200, 250, 300, 350),
scale_to_km = TRUE,
n_permutation = 10000)
plot_s_variogram(liberia_variog)
plot_s_variogram(liberia_variog,
plot_envelope = TRUE)
