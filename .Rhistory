den = ntest,
par0 = theta0,
family = "binomial",
data = liberia_sf)
summary(lb_fit)
lb_fit_n <- glgpm(npos ~ log(elevation) + gp(nugget = NULL),
den = ntest,
family = "binomial",
data = liberia_sf)
summary(lb_fit_n)
