pred_T_lb <-
pred_target_grid(pred_S_lb,
f_target = list(prev = function(x) exp(x)/(1+exp(x))),
pd_summary = list(mean = mean,
lower_lim = function(x) quantile(x, 0.025),
upper_lim = function(x) quantile(x, 0.975),
